{
  "manifest_version": 3,
  "name": "Niche Finder Chrome Extension",
  "version": "1.0",
  "description": "Premium YouTube Channel Analytics & Outlier Research Extension synced with Waqasalee.com.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "https://waqasalee.com/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "monetized.png",
        "checking.png",
        "demonetized.png"
      ],
      "matches": [
        "https://*.youtube.com/*"
      ]
    }
  ]
}
