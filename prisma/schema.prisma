generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── NextAuth User Management ─────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user")     // admin | user
  status        String    @default("pending")  // pending | active | blocked
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  signInLogs    SignInLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model SignInLog {
  id         String   @id @default(cuid())
  userId     String
  signedInAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── YouTube Channel Research ─────────────────────────────────────────────────

model Channel {
  id                String   @id @default(cuid())
  channelId         String   @unique
  channelName       String
  channelHandle     String?
  thumbnailUrl      String?
  subscribers       Int      @default(0)
  totalVideos       Int      @default(0)
  totalViews        BigInt   @default(0)
  channelType       String
  niche             String?
  daysSinceStart    Int      @default(0)
  avgViewsPerVideo  Float    @default(0)
  outlierScore      Float    @default(0)
  isMonetized       Boolean  @default(false)
  isActive          Boolean  @default(true)
  isKids            Boolean  @default(false)
  isNews            Boolean  @default(false)
  isEntertainment   Boolean  @default(false)
  isFaceless        Boolean  @default(false)
  isAi              Boolean  @default(false)
  isNano            Boolean  @default(false)
  sortOrder         Int      @default(0)
  shortsRatioLast30d Float   @default(0)
  lastCategorizedAt DateTime?
  avgVideoLength    Int      @default(0)
  monthlyViews      BigInt   @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  videos            Video[]

  @@index([isActive, channelType])
  @@index([isActive, channelType, niche])
  @@index([isActive, outlierScore])
  @@index([isActive, subscribers])
  @@index([isActive, avgViewsPerVideo])
  @@index([isActive, sortOrder])
  @@index([isActive, isKids])
  @@index([isActive, isNews])
  @@index([isActive, isEntertainment])
  @@index([isActive, isFaceless])
  @@index([isActive, isAi])
  @@index([niche])
  @@index([subscribers])
  @@index([outlierScore])
  @@index([sortOrder])
  @@index([channelType, isActive, sortOrder])
}

model Video {
  id           String    @id @default(cuid())
  videoId      String    @unique
  channelId    String
  title        String
  thumbnailUrl String?
  views        BigInt    @default(0)
  duration     String?
  publishedAt  DateTime?
  language     String?
  isOutlier    Boolean   @default(false)
  isNano       Boolean   @default(false)
  isShort      Boolean   @default(false)
  channel      Channel   @relation(fields: [channelId], references: [channelId])

  @@index([channelId])
  @@index([channelId, views])
  @@index([views])
  @@index([isOutlier])
  @@index([publishedAt])
}

