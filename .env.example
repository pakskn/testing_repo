# ═══════════════════════════════════════════════════════
#  Niche Finder — Environment Variables
#  Copy this file to .env and fill in real values
#  NEVER commit .env to GitHub!
# ═══════════════════════════════════════════════════════

# ── Database (Docker internal) ──────────────────────────
DB_USER=nicheuser
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=nichefinder

# ── Prisma Connection (uses Docker service name "postgres") ──
# Appending connection_limit=25 & pool_timeout=10 optimizes connection pooling under high concurrency
DATABASE_URL=postgresql://nicheuser:CHANGE_THIS_STRONG_PASSWORD@postgres:5432/nichefinder?connection_limit=25&pool_timeout=10

# ── YouTube Data API v3 ──────────────────────────────────
# Get from: console.cloud.google.com → APIs → YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# ── Google OAuth ──────────────────────────────────────────
# Get from: console.cloud.google.com → Credentials → OAuth 2.0
# Authorized redirect URI: https://yourdomain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── NextAuth / Auth.js v5 ────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET=generate_32_char_random_string_here
AUTH_SECRET=generate_32_char_random_string_here
# Local: http://localhost:3000 | Production: https://yourdomain.com
NEXTAUTH_URL=https://niches.yourdomain.com
# Set to true for non-Vercel hosting (e.g. VPS or local dev custom port)
AUTH_TRUST_HOST=true

# ── Admin ────────────────────────────────────────────────
# This email gets auto-approved as admin on first login
ADMIN_EMAIL=your_admin_email@gmail.com

# ── Domain (for docker-compose.prod.yml + Traefik) ───────
DOMAIN=niches.yourdomain.com

# ── API Rate Limiting (Configurable) ─────────────────────
# General rate limiting (100 requests per minute for normal users)
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# Admin rate limiting (30 requests per minute for admin actions)
RATE_LIMIT_ADMIN_MAX=30
RATE_LIMIT_ADMIN_WINDOW_MS=60000

# Clustered Deployment (Optional: Upstash Redis Free Tier)
# UPSTASH_REDIS_REST_URL=https://your-upstash-instance.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
