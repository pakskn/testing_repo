# ═══════════════════════════════════════════════════════
#  Niche Finder — Perfect .gitignore
#  Next.js + Prisma + Python + Docker + Node
# ═══════════════════════════════════════════════════════

# ── SECRETS — NEVER commit these ───────────────────────
.env
.env.local
.env.production
.env.development
next-app/.env
next-app/.env.local
next-app/.env.production
data-collector/.env
*.env

# ── Node / Next.js ──────────────────────────────────────
node_modules/
next-app/node_modules/
.next/
next-app/.next/
out/
next-app/out/
build/
next-app/build/
.vercel/

# ── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.pyc
*.pyo
.Python
env/
venv/
.venv/
*.egg-info/
dist/
.pytest_cache/
data-collector/__pycache__/
data-collector/.venv/

# ── Prisma / SQLite (local dev only) ────────────────────
next-app/prisma/*.db
next-app/prisma/*.db-journal
prisma/*.db
prisma/*.db-journal

# ── Logs ────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/tmp/

# ── OS / IDE ─────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Docker ──────────────────────────────────────────────
.dockerignore

# ── Temp / Backup ───────────────────────────────────────
data-collector/_backup.txt
*.tmp
*.bak
